# CareFlow AI — Environment Configuration
# Copy this to .env and add your actual API key

# ── AI Provider ──────────────────────────────────────────────────────────────
# Google Gemini API Key (free tier — get at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-google-api-key-here
AI_MODEL=gemini-2.0-flash

# ── FHIR Configuration ──────────────────────────────────────────────────────
# Public HAPI FHIR R4 sandbox (no auth needed for testing)
FHIR_SANDBOX_URL=https://hapi.fhir.org/baseR4

# ── Server Configuration ────────────────────────────────────────────────────
# Port for the MCP server (Railway sets this automatically)
PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
